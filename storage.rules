rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Only authenticated users who are on the allowlist can read/write storage.
      // Note: Storage rules cannot call Firestore; we rely on app-level auth check.
      // The allowlist check is enforced in the app code (AuthContext).
      allow read, write: if request.auth != null;
    }
  }
}
